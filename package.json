{
  "name": "@seedquan/picnote",
  "version": "0.1.0",
  "description": "AI-powered photo intelligence — monitors iPhone photos via iCloud, classifies and extracts info, generates searchable Markdown notes",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "picnote": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": ["photo", "ai", "ocr", "screenshot", "notes", "markdown", "icloud"],
  "author": "seedquan",
  "license": "MIT",
  "files": [
    "dist",
    "swift/vision_ocr.swift",
    "config.yaml",
    "resources"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
