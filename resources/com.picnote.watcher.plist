<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.picnote.watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-m</string>
        <string>src.main</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/iris/Projects/picnote</string>

    <key>WatchPaths</key>
    <array>
        <string>/Users/iris/Pictures/Photos Library.photoslibrary/database/Photos.sqlite-wal</string>
    </array>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/iris/Documents/PicNote/logs/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/iris/Documents/PicNote/logs/launchd-stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
